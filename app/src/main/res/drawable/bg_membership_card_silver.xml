<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base gradient: cool silver -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#37474F"
                android:centerColor="#607D8B"
                android:endColor="#90A4AE"
                android:angle="135"
                android:type="linear" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- Metallic shimmer overlay -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#18FFFFFF"
                android:centerColor="#00FFFFFF"
                android:endColor="#10FFFFFF"
                android:angle="45"
                android:type="linear" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>
