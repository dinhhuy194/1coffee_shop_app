<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/privilegeCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Icon Emoji -->
        <TextView
            android:id="@+id/privilegeIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:textSize="24sp"
            android:background="#F5F5F5"
            android:text="☕" />

        <!-- Thông tin đặc quyền -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/privilegeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ưu đãi sinh nhật"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/darkBrown" />

            <TextView
                android:id="@+id/privilegeDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Miễn phí 1 ly vào ngày sinh nhật"
                android:textSize="13sp"
                android:textColor="@color/grey" />
        </LinearLayout>

        <!-- Badge hạng yêu cầu -->
        <TextView
            android:id="@+id/privilegeRankBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="Silver"
            android:textSize="11sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:background="#546E7A"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
