<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="14dp"
    android:gravity="center_vertical">

    <!-- Icon +/- -->
    <TextView
        android:id="@+id/historyIconBg"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:textSize="18sp"
        android:text="☕"
        android:background="@color/pointPositiveBg" />

    <!-- Lý do và thời gian -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/historyReason"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Order #ABC123"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/darkBrown" />

        <TextView
            android:id="@+id/historyTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="22/02/2026 - 10:30"
            android:textSize="12sp"
            android:textColor="@color/grey" />
    </LinearLayout>

    <!-- Delta BEAN -->
    <TextView
        android:id="@+id/historyDelta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+50 BEAN"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/pointPositive"
        android:layout_marginStart="8dp" />

</LinearLayout>
