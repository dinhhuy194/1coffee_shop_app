<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lightCream"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Checkout"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/darkBrown"
            android:layout_marginBottom="24dp" />

        <!-- Order Summary -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Order Summary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/darkBrown"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/white_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Subtotal"
                    android:textColor="@color/darkBrown" />

                <TextView
                    android:id="@+id/subtotalTxt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textStyle="bold"
                    android:textColor="@color/darkBrown" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tax"
                    android:textColor="@color/darkBrown" />

                <TextView
                    android:id="@+id/taxTxt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textStyle="bold"
                    android:textColor="@color/darkBrown" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Delivery"
                    android:textColor="@color/darkBrown" />

                <TextView
                    android:id="@+id/deliveryTxt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textStyle="bold"
                    android:textColor="@color/darkBrown" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/grey"
                android:layout_marginVertical="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Total"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/darkBrown" />

                <TextView
                    android:id="@+id/totalTxt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/orange" />
            </LinearLayout>
        </LinearLayout>

        <!-- Payment Method -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Payment Method"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/darkBrown"
            android:layout_marginBottom="16dp" />

        <RadioGroup
            android:id="@+id/paymentMethodGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/white_bg"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/cashRadio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💵 Cash on Delivery"
                android:textSize="16sp"
                android:checked="true" />

            <RadioButton
                android:id="@+id/vnpayRadio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🏦 Thanh toán qua VNPAY"
                android:textSize="16sp"
                android:layout_marginTop="8dp" />
            <RadioButton
                android:id="@+id/momoRadio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="  Thanh toán qua MOMO"
                android:textSize="16sp"
                android:drawableStart="@drawable/ic_momo"
                android:layout_marginTop="8dp" />

            <RadioButton
                android:id="@+id/cardRadio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💳 Credit/Debit Card (Coming soon)"
                android:textSize="16sp"
                android:enabled="false"
                android:layout_marginTop="8dp" />
        </RadioGroup>

        <!-- Delivery Address - Chọn từ bản đồ hoặc tìm kiếm trực tiếp -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Delivery Address"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/darkBrown"
            android:layout_marginBottom="12dp" />

        <!-- Trường kết hợp: hiển thị địa chỉ hiện tại + tìm kiếm khi nhấn vào -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/white_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍"
                android:textSize="18sp"
                android:layout_marginEnd="8dp" />

            <!-- Hiển thị địa chỉ đã lưu; khi nhấn vào cho phép tìm kiếm -->
            <EditText
                android:id="@+id/checkoutAddressSearchEdit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Vui lòng chọn địa chỉ giao hàng"
                android:textSize="14sp"
                android:textColor="@color/darkBrown"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"
                android:maxLines="1" />

            <!-- Nút xóa text (chỉ hiện khi đang gõ tìm kiếm) -->
            <TextView
                android:id="@+id/checkoutClearSearchBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕"
                android:textSize="16sp"
                android:textColor="@color/grey"
                android:padding="6dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- ProgressBar khi đang tìm kiếm -->
        <ProgressBar
            android:id="@+id/checkoutSearchProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:indeterminate="true"
            android:visibility="gone"
            android:layout_marginBottom="2dp" />

        <!-- Danh sách gợi ý địa chỉ (hiện khi có kết quả) -->
        <ListView
            android:id="@+id/checkoutSuggestionsList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/white_bg"
            android:divider="@color/lightGrey"
            android:dividerHeight="1dp"
            android:maxHeight="200dp"
            android:visibility="gone"
            android:layout_marginBottom="10dp" />

        <!-- Nút chọn địa chỉ trực tiếp trên bản đồ -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/selectAddressBtn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/stroke_brown_bg"
            android:text="🗺️ CHỌN TRÊN BẢN ĐỒ"
            android:textColor="@color/darkBrown"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp" />

        <!-- Place Order Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/placeOrderBtn"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/orange_bg"
            android:text="Place Order"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
