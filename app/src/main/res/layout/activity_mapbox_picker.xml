<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout cho MapboxPickerActivity - Chọn địa chỉ giao hàng trên bản đồ.

    Cấu trúc (từ dưới lên theo elevation):
    1. MapView - bản đồ full screen (base layer)
    2. ImageView - ghim marker cố định tại tâm
    3. CardView (top) - Search bar + danh sách gợi ý địa chỉ
    4. FAB back (góc trên trái)
    5. FAB my location (góc phải, giữa)
    6. CardView (bottom) - địa chỉ tạm thời + nút xác nhận
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Bản đồ Mapbox full screen (base layer) -->
    <com.mapbox.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Ghim marker cố định tại tâm bản đồ -->
    <!-- marginBottom = 24dp để đáy ghim trùng khớp với tâm map (bù chiều cao icon) -->
    <ImageView
        android:id="@+id/pinMarker"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp"
        android:src="@drawable/ic_map_pin"
        android:contentDescription="Marker pin"
        android:elevation="8dp" />

    <!-- === TOP SECTION: Search Bar + Suggestions === -->
    <LinearLayout
        android:id="@+id/topSearchContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:layout_marginTop="48dp"
        android:layout_marginHorizontal="12dp"
        android:elevation="12dp">

        <!-- Search Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp">

                <!-- Icon kính lúp -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍"
                    android:textSize="18sp"
                    android:layout_marginEnd="8dp" />

                <!-- Input tìm kiếm địa chỉ -->
                <EditText
                    android:id="@+id/searchAddressEditText"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Tìm kiếm địa chỉ..."
                    android:textSize="14sp"
                    android:textColor="@color/darkBrown"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:singleLine="true"
                    android:maxLines="1" />

                <!-- Nút xóa text (visible khi có text) -->
                <TextView
                    android:id="@+id/clearSearchBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✕"
                    android:textSize="16sp"
                    android:textColor="@color/grey"
                    android:padding="8dp"
                    android:visibility="gone" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Danh sách gợi ý địa chỉ (hiện khi có kết quả search) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/suggestionsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/white"
            android:visibility="gone">

            <ListView
                android:id="@+id/suggestionsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:divider="@color/lightGrey"
                android:dividerHeight="1dp"
                android:maxHeight="240dp" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Nút quay lại (dưới search bar, trái) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/backBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|start"
        android:layout_margin="12dp"
        android:src="@android:drawable/ic_menu_revert"
        android:contentDescription="Quay lại"
        app:fabSize="mini"
        app:backgroundTint="@color/white"
        app:tint="@color/darkBrown"
        app:elevation="6dp" />

    <!-- Nút "Về vị trí hiện tại" (giữa phải) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/myLocationBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|end"
        android:layout_margin="12dp"
        android:src="@android:drawable/ic_menu_mylocation"
        android:contentDescription="Vị trí hiện tại"
        app:fabSize="mini"
        app:backgroundTint="@color/white"
        app:tint="@color/orange"
        app:elevation="6dp" />

    <!-- Bottom Card: Địa chỉ tạm thời + nút xác nhận -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bottomCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Tiêu đề -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📍 Địa chỉ giao hàng"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/darkBrown"
                android:layout_marginBottom="8dp" />

            <!-- Địa chỉ tạm thời (cập nhật khi camera dừng hoặc chọn từ gợi ý) -->
            <TextView
                android:id="@+id/tempAddressTxt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Kéo bản đồ hoặc tìm kiếm địa chỉ..."
                android:textSize="14sp"
                android:textColor="@color/grey"
                android:minLines="2"
                android:maxLines="3"
                android:layout_marginBottom="16dp" />

            <!-- ProgressBar khi đang geocoding -->
            <ProgressBar
                android:id="@+id/geocodeProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:indeterminate="true"
                android:visibility="gone"
                android:layout_marginBottom="12dp" />

            <!-- Nút xác nhận địa chỉ -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/confirmAddressBtn"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/orange_bg"
                android:text="✅ Xác nhận địa chỉ này"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:enabled="false" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</FrameLayout>
