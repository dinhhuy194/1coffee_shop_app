<?xml version="1.0" encoding="utf-8"?>
<!--
    BottomNavBar – dùng LinearLayout đơn giản thay vì BottomNavigationView
    (BottomNavigationView chỉ hỗ trợ Menu items, không phải custom children)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/darkBrown"
    android:orientation="horizontal"
    android:elevation="8dp"
    android:minHeight="70dp">

    <!-- Explorer -->
    <LinearLayout
        android:id="@+id/navExplorer"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="8dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            app:srcCompat="@drawable/btn_1" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Khám phá"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Cart -->
    <LinearLayout
        android:id="@+id/navCart"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="8dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            app:srcCompat="@drawable/btn_2" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Giỏ hàng"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Favourite -->
    <LinearLayout
        android:id="@+id/navFavourite"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="8dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            app:srcCompat="@drawable/btn_3" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Yêu thích"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- My Order -->
    <LinearLayout
        android:id="@+id/navOrder"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="8dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            app:srcCompat="@drawable/btn_4" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Đơn hàng"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Profile -->
    <LinearLayout
        android:id="@+id/navProfile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="8dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            app:srcCompat="@drawable/btn_5" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Hồ sơ"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="10sp" />
    </LinearLayout>

</LinearLayout>
