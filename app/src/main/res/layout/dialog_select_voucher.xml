<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/lightCream">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="@color/grey"
        android:alpha="0.4" />

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🎫 Voucher của tôi"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/darkBrown" />

        <TextView
            android:id="@+id/closeVoucherDialog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕"
            android:textSize="18sp"
            android:textColor="@color/grey"
            android:padding="6dp" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/grey"
        android:alpha="0.2" />

    <!-- Empty state (ẩn mặc định) -->
    <LinearLayout
        android:id="@+id/emptyVoucherState"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="😔"
            android:textSize="40sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Bạn chưa có voucher nào"
            android:textSize="14sp"
            android:textColor="@color/grey" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Đổi BEAN để nhận voucher ngay!"
            android:textSize="12sp"
            android:textColor="@color/grey" />
    </LinearLayout>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/voucherLoadingProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginVertical="20dp"
        android:visibility="gone" />

    <!-- Danh sách voucher -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/voucherRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="360dp"
        android:nestedScrollingEnabled="true"
        android:padding="16dp"
        android:clipToPadding="false" />

    <!-- Nút bỏ chọn (ẩn khi chưa chọn) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/removeVoucherBtn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp"
        android:text="Bỏ chọn voucher"
        android:textSize="14sp"
        android:visibility="gone"
        app:strokeColor="@color/orange"
        app:strokeWidth="1dp"
        app:backgroundTint="@color/white"
        android:textColor="@color/orange"
        app:cornerRadius="8dp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

</LinearLayout>
