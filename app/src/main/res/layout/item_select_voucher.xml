<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/voucherSelectCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="2dp"
    app:strokeColor="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Icon Emoji -->
        <TextView
            android:id="@+id/selectVoucherIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:textSize="26sp"
            android:background="#FFF3E0"
            android:text="🎫" />

        <!-- Thông tin voucher -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="10dp">

            <TextView
                android:id="@+id/selectVoucherName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giảm 10.000đ"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/darkBrown"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/selectVoucherDiscount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Giảm 10.000đ"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/orange" />

            <TextView
                android:id="@+id/selectVoucherDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Áp dụng cho đơn từ 50k"
                android:textSize="11sp"
                android:textColor="@color/grey"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Radio button chọn -->
        <RadioButton
            android:id="@+id/selectVoucherRadio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="false"
            android:buttonTint="@color/orange" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
