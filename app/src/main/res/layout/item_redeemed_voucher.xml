<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Icon Emoji -->
        <TextView
            android:id="@+id/voucherIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:textSize="28sp"
            android:background="@drawable/bg_membership_card_normal"
            android:text="🎫" />

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="12dp">

            <TextView
                android:id="@+id/voucherName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giảm 10%"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/darkBrown"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/voucherDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Giảm 10% cho đơn hàng tiếp theo"
                android:textSize="12sp"
                android:textColor="@color/grey"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/voucherDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Đổi: 22/02/2026"
                android:textSize="11sp"
                android:textColor="@color/grey" />

        </LinearLayout>

        <!-- Status / Action -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Status Badge -->
            <TextView
                android:id="@+id/statusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="Chưa dùng"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/bg_membership_card_gold" />

            <!-- Use Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/useBtn"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginTop="6dp"
                android:text="Sử dụng"
                android:textSize="11sp"
                app:cornerRadius="18dp"
                app:backgroundTint="@color/rankNormal"
                style="@style/Widget.MaterialComponents.Button" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
